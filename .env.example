# OriSelf Next App · 环境变量示例
# 复制为 `.env`，填入你自己的 API key。不提交到 git。

# ═══════════════ Server (FastAPI) ═══════════════

# 默认 LLM provider（mock 不需要密钥）
ORISELF_PROVIDER=mock

# SQLite 文件路径（Docker 内）
ORISELF_DB_PATH=/data/oriself.db

# Skill 路径（Docker 默认 /app/skill-repo/skills/oriself，本地自动用 submodule）
# ORISELF_SKILL_ROOT=/app/skill-repo/skills/oriself

# CORS（生产收紧，如 "https://next.oriself.com"）
ORISELF_CORS_ORIGINS=*

# ─────── LLM provider API keys（至少填一个） ───────

# DeepSeek
# ORISELF_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# ORISELF_DEEPSEEK_MODEL=deepseek-chat

# Qwen (DashScope)
# ORISELF_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
# ORISELF_QWEN_MODEL=qwen-max

# Kimi (Moonshot)
# ORISELF_KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx
# ORISELF_KIMI_MODEL=moonshot-v1-32k

# OpenAI
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# ORISELF_OPENAI_MODEL=gpt-4o-mini


# ═══════════════ Web (Next.js) ═══════════════

# 浏览器可见的 API URL（dev: localhost，prod: api.oriself.com）
NEXT_PUBLIC_API_URL=http://localhost:8000

# 服务端内部 API URL（docker-compose 内部用 service name）
API_INTERNAL_URL=http://server:8000
